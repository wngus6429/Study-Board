        <mxCell id="resourceNotes" value="&lt;b&gt;Resource Summary&lt;/b&gt;&lt;br&gt;Public subnet routes 0.0.0.0/0 to IGW.&lt;br&gt;Private subnet 1 routes 0.0.0.0/0 to NAT Gateway.&lt;br&gt;Backend EC2 is reached through the bastion host.&lt;br&gt;RDS is modeled as private database access.&lt;br&gt;S3 is modeled as external regional object storage used by the app." style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;fillColor=#ffffff;strokeColor=#94a3b8;fontColor=#0f172a;fontSize=13;align=left;spacing=12;" vertex="1" parent="cloud">
